# ============================================================
# bMS 人事・売上統合システム 環境変数テンプレート
# ============================================================
# 実際の値を .env ファイルにコピー＆編集してください
# .env ファイルは Git にコミットしてはいけません
# サーバへは FTP で .env を手動アップロードしてください
# ============================================================

# --- データベース ---
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_CHARSET=utf8mb4

# --- アプリケーション ---
APP_NAME=bMS - タレントマネジメントシステム
APP_VERSION=1.0.0
BASE_PATH=/bms

# --- デバッグ設定 (本番は false) ---
DEBUG_MODE=false

# --- FTP デプロイ (deploy_ftp.py で使用) ---
FTP_HOST=sv904.xbiz.ne.jp
FTP_USER=your_ftp_user
FTP_PASS=your_ftp_password
FTP_REMOTE_BASE=/your_domain/public_html/bms
